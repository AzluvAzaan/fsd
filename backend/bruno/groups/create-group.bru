meta {
  name: Create Group
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/groups
  body: json
  auth: none
}

headers {
  Content-Type: application/json
  X-User-ID: {{userId}}
}

body:json {
  {
    "name": "Alice & Bob Team"
  }
}

script:post-response {
  const body = res.getBody();
  bru.setVar("groupId", body.id);
  bru.setVar("inviteCode", body.inviteLink);
}


